# Anthropic API key — required for `paygraph demo --live`
ANTHROPIC_API_KEY=

# OpenAI API key — required for `paygraph demo --live --model openai`
OPENAI_API_KEY=

# Stripe API key — required for `paygraph demo --live --stripe` or `--stripe-mpp`
# Get a test key at https://dashboard.stripe.com/test/apikeys
STRIPE_API_KEY=

# Optional Stripe configuration
# STRIPE_CURRENCY=eur
# STRIPE_BILLING_COUNTRY=FR
# STRIPE_CARDHOLDER_ID=ich_...

# Stripe MPP (Shared Payment Tokens) — for StripeMPPGateway (preview API)
# STRIPE_MPP_PAYMENT_METHOD=pm_...
# STRIPE_MPP_GRANTEE=profile_...
# STRIPE_MPP_EXPIRES_IN_SECONDS=600
