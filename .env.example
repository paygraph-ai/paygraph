# Anthropic API key — required for `paygraph demo --live`
ANTHROPIC_API_KEY=

# OpenAI API key — required for `paygraph demo --live --model openai`
OPENAI_API_KEY=

# Stripe API key — required for `paygraph demo --live --stripe`
# Get a test key at https://dashboard.stripe.com/test/apikeys
STRIPE_API_KEY=

# Optional Stripe configuration
# STRIPE_CURRENCY=eur
# STRIPE_BILLING_COUNTRY=FR
# STRIPE_CARDHOLDER_ID=ich_...
